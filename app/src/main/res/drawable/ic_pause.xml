<?xml version="1.0" encoding="utf-8"?>
<!--
  Pause state — Ermite sky blue circle, white pause glyph (two bars).
  Shown when stream is live and not paused (button starts pause).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#CC3DC3FF" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
    <item
        android:left="18dp"
        android:top="16dp"
        android:right="32dp"
        android:bottom="16dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
    <item
        android:left="32dp"
        android:top="16dp"
        android:right="18dp"
        android:bottom="16dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
</layer-list>
