<?xml version="1.0" encoding="utf-8"?>
<!-- Container pilule pour la rangée EXPANDED. Fond dark-glass opaque
     90% pour rester lisible au-dessus de n'importe quel jeu. Bordure
     subtile pour détacher du fond. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#E60F1729" />
    <stroke android:width="1dp" android:color="#FF2A3660" />
    <corners android:radius="32dp" />
</shape>
