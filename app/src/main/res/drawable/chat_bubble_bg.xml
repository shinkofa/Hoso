<?xml version="1.0" encoding="utf-8"?>
<!--
  Background for the chat overlay window. Lighter elevation than the
  control overlay (which uses elevation 8dp / border 40%) so the chat
  reads as a secondary surface beside the primary controls.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#E60F1729" />
    <stroke
        android:width="1dp"
        android:color="#402A3660" />
    <corners android:radius="10dp" />
</shape>
