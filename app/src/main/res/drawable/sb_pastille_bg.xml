<?xml version="1.0" encoding="utf-8"?>
<!-- Small status dot sitting on the COLLAPSED trigger when the
     Streamer.bot bridge is CONNECTED (G6.1 Phase E.1). Green to
     differentiate from the sky-blue chat pastille, so a quick glance
     tells the streamer which of the two side-services is live. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#FF4ADE80" />
    <stroke android:width="1dp" android:color="#FF0F1729" />
</shape>
