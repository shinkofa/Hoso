<?xml version="1.0" encoding="utf-8"?>
<!--
  Privacy mode active — Ermite danger red circle with a closed-eye
  glyph (horizontal bar over a curve), signaling that what is captured
  is currently hidden from viewers.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#CCF87171" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
    <item
        android:left="14dp"
        android:top="26dp"
        android:right="14dp"
        android:bottom="26dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
