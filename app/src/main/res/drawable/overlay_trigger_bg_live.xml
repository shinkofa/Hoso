<?xml version="1.0" encoding="utf-8"?>
<!-- Variante "live" du cercle de fond du trigger COLLAPSED.
     Même dark-glass que overlay_trigger_bg pour la continuité, mais
     contour rouge vif (rappel du point rouge "REC" des caméras) :
     signal d'un coup d'œil que le stream est en cours. Le fond
     reste sombre pour ne pas cogner visuellement par-dessus le jeu. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#E60F1729" />
    <stroke android:width="2dp" android:color="#FFFF3B30" />
</shape>
