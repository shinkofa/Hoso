<?xml version="1.0" encoding="utf-8"?>
<!--
  Visible "resize handle" indicator at the bottom of the chat bubble.
  The dot itself lives in the body window (which is FLAG_NOT_TOUCHABLE
  so touches fall through to the game). A separate transparent overlay
  window catches the actual tap and cycles size S/M/L.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#B3FFFFFF" />
    <size android:width="12dp" android:height="12dp" />
</shape>
