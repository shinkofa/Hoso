<!--
  Polish pass — chevron icon for collapsible Material cards on the main
  screen. Rendered at 20dp in the section header row, rotated 180° (via
  ImageView.rotation) when its card body is collapsed so the chevron
  points up. Tinted to text_secondary so it sits in the same visual
  layer as the section label without competing with it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="@color/text_secondary">
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M7.41,8.59 L12,13.17l4.59,-4.58L18,10l-6,6 -6,-6z" />
</vector>
