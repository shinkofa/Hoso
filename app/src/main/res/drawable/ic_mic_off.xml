<?xml version="1.0" encoding="utf-8"?>
<!--
  Mic OFF state — Ermite danger red circle, dim white mic glyph + cross bar.
  Used in the overlay control row when mic is muted.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#CCF87171" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
    <item
        android:left="14dp"
        android:top="12dp"
        android:right="14dp"
        android:bottom="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#80FFFFFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item
        android:left="22dp"
        android:top="32dp"
        android:right="22dp"
        android:bottom="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#80FFFFFF" />
        </shape>
    </item>
    <!-- Diagonal strike-through bar -->
    <item
        android:left="10dp"
        android:top="26dp"
        android:right="10dp"
        android:bottom="26dp">
        <rotate android:fromDegrees="-30">
            <shape android:shape="rectangle">
                <solid android:color="#FFFFFFFF" />
            </shape>
        </rotate>
    </item>
</layer-list>
