<?xml version="1.0" encoding="utf-8"?>
<!--
  Mic ON state — Ermite sky blue circle, white mic glyph.
  Used in the overlay control row when mic is active (not muted).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#CC3DC3FF" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
    <item
        android:left="14dp"
        android:top="12dp"
        android:right="14dp"
        android:bottom="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item
        android:left="22dp"
        android:top="32dp"
        android:right="22dp"
        android:bottom="14dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
</layer-list>
