<?xml version="1.0" encoding="utf-8"?>
<!--
  État COLLAPSED de l'overlay Hoso (G4.5).
  Un seul élément discret, draggable, qui sert à la fois de
  marqueur de présence ("l'overlay est là") et de bouton d'ouverture
  (tap court → EXPANDED).
  Position : libre, déplaçable par drag (sauvegardée dans l'état
  service tant que le service vit).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/collapsed_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/btn_trigger"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_overlay_trigger"
        android:contentDescription="@string/overlay_trigger_label" />

</FrameLayout>
