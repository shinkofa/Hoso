<?xml version="1.0" encoding="utf-8"?>
<!--
  Hoso live stream overlay control row.
  Floating, draggable as a whole. Each child is a tap target.
  Order is the on-screen order: mic mute, privacy mask, pause, stop.
  G3.2 + G3.3 add the privacy and pause children — for G3.1 only
  mic + stop are wired; the others remain present but hidden until
  their feature commits land.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/btn_mic"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="6dp"
        android:src="@drawable/ic_mic_on"
        android:contentDescription="@string/btn_mute" />

    <ImageView
        android:id="@+id/btn_privacy"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="6dp"
        android:visibility="gone"
        android:contentDescription="@string/btn_privacy" />

    <ImageView
        android:id="@+id/btn_pause"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="6dp"
        android:visibility="gone"
        android:contentDescription="@string/btn_pause" />

    <ImageView
        android:id="@+id/btn_stop"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_stop_overlay"
        android:contentDescription="@string/btn_stop" />

</LinearLayout>
