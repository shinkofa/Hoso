<?xml version="1.0" encoding="utf-8"?>
<!--
  Hoso live stream overlay control row.
  Floating, draggable as a whole. Each child is a tap target.
  Order is the on-screen order: mic mute, privacy mask, pause, stop.
  All four children are wired post-G3.3: mic toggles audio, privacy
  toggles the opaque mask + force-mute combo, pause uses the same
  mask machinery with a different label, stop tears down the stream.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/btn_mic"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="6dp"
        android:src="@drawable/ic_mic_on"
        android:contentDescription="@string/btn_mute" />

    <ImageView
        android:id="@+id/btn_privacy"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="6dp"
        android:src="@drawable/ic_privacy_off"
        android:contentDescription="@string/btn_privacy" />

    <ImageView
        android:id="@+id/btn_pause"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="6dp"
        android:src="@drawable/ic_pause"
        android:contentDescription="@string/btn_pause" />

    <ImageView
        android:id="@+id/btn_stop"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_stop_overlay"
        android:contentDescription="@string/btn_stop" />

</LinearLayout>
