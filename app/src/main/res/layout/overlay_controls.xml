<?xml version="1.0" encoding="utf-8"?>
<!--
  Hoso live stream overlay control row (état EXPANDED — G4.5).
  Affiché au centre de l'écran sur tap du trigger collapsed.
  Contient une zone HUD (réservée G5.1) au-dessus, et la rangée
  de boutons d'action en dessous. Tap sur btn_collapse referme
  l'overlay vers l'état COLLAPSED. Auto-collapse après 5 s d'inactivité.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <!--
      Zone HUD réservée pour G5.1 (durée, bitrate réseau réel, état).
      Masquée tant que G5.1 n'a pas câblé son contenu — la View occupe
      0 px en visibility="gone" donc zéro impact layout actuel.
    -->
    <TextView
        android:id="@+id/hud_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:padding="8dp"
        android:background="#CC0F1729"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/controls_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btn_collapse"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_overlay_trigger"
            android:contentDescription="@string/overlay_trigger_label" />

        <ImageView
            android:id="@+id/btn_mic"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_mic_on"
            android:contentDescription="@string/btn_mute" />

        <ImageView
            android:id="@+id/btn_privacy"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_privacy_off"
            android:contentDescription="@string/btn_privacy" />

        <ImageView
            android:id="@+id/btn_pause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_pause"
            android:contentDescription="@string/btn_pause" />

        <ImageView
            android:id="@+id/btn_chat"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/ic_chat"
            android:contentDescription="@string/btn_chat" />

        <ImageView
            android:id="@+id/btn_stop"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_stop_overlay"
            android:contentDescription="@string/btn_stop" />

    </LinearLayout>

    <!--
      G7.1 Phase B.2 — sliders de mix live (micro + jeu). Visibles
      uniquement quand la source audio = MIX. Largeur fixe en dp pour
      ne pas étirer la rangée de boutons sur les écrans larges.
      Le fond opaque sombre garantit la lisibilité du texte par-dessus
      n'importe quel jeu (light scene, sky, neige…).
    -->
    <LinearLayout
        android:id="@+id/overlay_mix_gains"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:padding="10dp"
        android:background="#CC0F1729"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_mic_gain"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/overlay_mic_gain_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/overlay_seekbar_mic_gain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="2000"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_game_gain"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/overlay_game_gain_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/overlay_seekbar_game_gain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="2000" />

    </LinearLayout>

</LinearLayout>
