<?xml version="1.0" encoding="utf-8"?>
<!--
  Polished main screen. Vertical LinearLayout split in two regions:
    1. ScrollView (weight 1) holds the configuration cards.
    2. Footer with a single Start/Stop action button is sticky at the
       bottom so the primary CTA is always reachable without scrolling.

  Sections are wrapped in MaterialCardView containers for visual
  hierarchy. Section headers are short ALL-CAPS labels with subtle
  color. Spacing is unified (16dp between cards, 12dp internal).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- Header row: title + status pill. Status replaces the
                 buried text label of the previous design and sits
                 next to the brand for quick visibility. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/status_pill_bg"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="@string/status_idle"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="@string/app_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <!-- ── Destination card ───────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Collapsible header — the whole row is clickable
                         (handled in MainActivity.bindCollapsible). The
                         chevron rotates 180° when the body is hidden. -->
                    <LinearLayout
                        android:id="@+id/header_destination"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.10"
                            android:text="@string/section_destination"
                            android:textColor="@color/purple_primary"
                            android:textSize="11sp" />

                        <ImageView
                            android:id="@+id/chevron_destination"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/card_toggle_desc"
                            android:src="@drawable/ic_chevron_down" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/body_destination"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="16dp">

                    <Spinner
                        android:id="@+id/spinner_preset"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/spinner_bg" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_preset_add"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="@string/preset_add"
                            android:textAllCaps="false"
                            android:textColor="@color/purple_primary"
                            android:textSize="14sp"
                            app:rippleColor="@color/purple_dark"
                            app:strokeColor="@color/purple_primary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_preset_edit"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginHorizontal="3dp"
                            android:layout_weight="1"
                            android:text="@string/preset_edit"
                            android:textAllCaps="false"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            app:rippleColor="@color/purple_dark"
                            app:strokeColor="@color/divider" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_preset_delete"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:text="@string/preset_delete"
                            android:textAllCaps="false"
                            android:textColor="@color/stream_stop"
                            android:textSize="14sp"
                            app:rippleColor="@color/stream_stop"
                            app:strokeColor="@color/stream_stop" />
                    </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Stream card ────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/header_stream"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.10"
                            android:text="@string/section_stream"
                            android:textColor="@color/purple_primary"
                            android:textSize="11sp" />

                        <ImageView
                            android:id="@+id/chevron_stream"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/card_toggle_desc"
                            android:src="@drawable/ic_chevron_down" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/body_stream"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:hint="@string/hint_stream_key"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_stream_key"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:singleLine="true" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/label_resolution"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/spinner_resolution"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="14dp"
                        android:background="@drawable/spinner_bg" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/label_bitrate"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="2dp">

                        <SeekBar
                            android:id="@+id/seekbar_bitrate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:min="0"
                            android:progressTint="@color/purple_primary"
                            android:thumbTint="@color/purple_primary" />

                        <TextView
                            android:id="@+id/text_bitrate_value"
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/bitrate_hint"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Audio card ─────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/header_audio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.10"
                            android:text="@string/section_audio"
                            android:textColor="@color/purple_primary"
                            android:textSize="11sp" />

                        <ImageView
                            android:id="@+id/chevron_audio"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@string/card_toggle_desc"
                            android:src="@drawable/ic_chevron_down" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/body_audio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="@string/label_audio_source"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/spinner_audio_source"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/spinner_bg" />

                    <!-- Mix gain sliders — visibles uniquement quand
                         audio_source = MIX. Visibility togglée par
                         MainActivity.applyMixSlidersVisibility(). -->
                    <LinearLayout
                        android:id="@+id/group_mix_gains"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_mic_gain"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_mic_gain_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekbar_mic_gain"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:max="2000" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_game_gain"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/text_game_gain_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekbar_game_gain"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="2000" />
                    </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Sticky footer with the unified Start/Stop action.
         backgroundTint is set programmatically by MainActivity between
         stream_start (idle → ready to go live) and stream_stop (live →
         tap to stop).
         A secondary discrete "Quitter" text button sits below to fully
         shut down all services (stream, overlay, chat) and remove the
         task. This is the clean session-end gesture —
         visible but visually subordinate to the primary CTA. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="@color/stream_start"
            android:text="@string/action_go_live"
            android:textColor="@color/background"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_quit"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:contentDescription="@string/action_quit_desc"
            android:text="@string/action_quit"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Re-open the first-launch onboarding on demand. -->
        <TextView
            android:id="@+id/text_replay_onboarding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:minHeight="44dp"
            android:padding="8dp"
            android:text="@string/onboarding_replay"
            android:textColor="@color/stream_start"
            android:textSize="13sp" />

        <!-- Phase C — in-app privacy policy access (Play Store requirement).
             Filled with the version name at runtime; tap opens the policy. -->
        <TextView
            android:id="@+id/text_about"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:padding="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            tools:text="Politique de confidentialité · v1.0.0 · Apache 2.0" />
    </LinearLayout>

</LinearLayout>
