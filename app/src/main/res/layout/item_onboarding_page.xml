<?xml version="1.0" encoding="utf-8"?>
<!--
  One onboarding page: decorative icon + title + body, centered. Text sizes
  and line spacing follow the ND-friendly minimums (>=16sp body, generous
  line height, high-contrast palette). The icon is decorative — the title
  carries the meaning for screen readers.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="32dp"
    android:paddingVertical="24dp">

    <ImageView
        android:id="@+id/onboarding_icon"
        android:layout_width="112dp"
        android:layout_height="112dp"
        android:layout_marginBottom="40dp"
        android:importantForAccessibility="no"
        android:scaleType="fitCenter"
        app:tint="@color/stream_start"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <TextView
        android:id="@+id/onboarding_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/onboarding_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:textColor="@color/text_secondary"
        android:textSize="16sp" />
</LinearLayout>
