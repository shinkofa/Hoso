<?xml version="1.0" encoding="utf-8"?>
<!--
  Une ligne du panneau actions Streamer.bot (G6.1 Phase E.1).
  Pill arrondie cliquable. Nom action en text_primary + groupe en
  text_secondary sous-titre quand présent. Hauteur compacte pour
  laisser 5 actions visibles dans 240×280 dp.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/action_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="4dp"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp"
    android:background="@drawable/overlay_btn_bg"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/action_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:ellipsize="end"
        android:maxLines="1" />

    <TextView
        android:id="@+id/action_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:ellipsize="end"
        android:maxLines="1"
        android:visibility="gone" />

</LinearLayout>
