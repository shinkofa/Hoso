<?xml version="1.0" encoding="utf-8"?>
<!--
  Fullscreen opaque mask shown over the captured display while the
  stream is in PAUSE or PRIVACY mode. The mask sits above the host
  app surface so MediaProjection captures it: the result is that
  viewers see this navy panel instead of the underlying game.
  The control row (overlay_controls) is re-added above this mask
  by OverlayService so the streamer can still tap Resume / mic / stop.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mask_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center">

        <TextView
            android:id="@+id/mask_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_pause"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/mask_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/app_name"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

    </LinearLayout>

</FrameLayout>
